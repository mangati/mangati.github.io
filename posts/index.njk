---
title: Blog
description: Notícias e tutoriais sobre os produtos Mangati
layout: post.njk
---

<div class="row row-cols-1 g-4 postlist">
    {%- for post in collections.posts | reverse %}
        <div class="col">
            <a href="{{ post.url }}" class="text-decoration-none">
                <div class="card h-100 postlist-card">
                    <div class="card-body">
                        <h2 class="card-title fs-5 mt-1 fw-semibold">{{ post.data.title }}</h2>
                        {% if post.data.description %}
                        <p class="card-text text-muted">{{ post.data.description }}</p>
                        {% endif %}
                    </div>
                    <div class="card-footer d-flex align-items-center justify-content-between">
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
                        </small>
                        <span class="postlist-readmore">
                            Ler mais <i class="bi bi-arrow-right"></i>
                        </span>
                    </div>
                </div>
            </a>
        </div>
    {%- endfor %}
</div>
