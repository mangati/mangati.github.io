---
layout: base.njk
---
<header class="home">
  <div class="pt-5 pb-3 mb-4">
    <div class="container py-3">
      <h1 id="about" class="display-6 fw-bold">{{ title }}</h1>
      <p class="col-md-8 fs-4">{{ description }}</p>
    </div>
  </div>
</header>
<article>
  <section id="posts" class="py-2">
    <div class="container">
      {% if collections.posts and page.url != "/posts/" %}
      <nav aria-label="breadcrumb" class="mb-3">
        <a href="/posts/" class="d-inline-flex align-items-center gap-1">
          <i class="bi bi-arrow-left"></i> Todos os posts
        </a>
      </nav>
      {% endif %}
      {{ content | safe }}
    </div>
  </section>
</article>
{% if collections.posts and page.url != "/posts/" %}
<section id="recent-posts" class="py-4">
  <div class="container">
    <h2 class="fs-5 fw-semibold mb-3">Posts recentes</h2>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      {%- for post in collections.posts | reverse | limit(3) %}
      <div class="col">
        <a href="{{ post.url }}" class="text-decoration-none">
          <div class="card h-100 postlist-card">
            <div class="card-body">
              <h3 class="card-title fs-6 fw-semibold">{{ post.data.title }}</h3>
              {% if post.data.description %}
              <p class="card-text text-muted small">{{ post.data.description }}</p>
              {% endif %}
            </div>
            <div class="card-footer d-flex align-items-center justify-content-between">
              <small class="text-muted">
                <i class="bi bi-calendar3 me-1"></i>
                <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
              </small>
              <span class="postlist-readmore">
                Ler mais <i class="bi bi-arrow-right"></i>
              </span>
            </div>
          </div>
        </a>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>
{% endif %}
