---
layout: base.njk
---
<header{% if headerColor %} style="--bg-color: {{ headerColor }}"{% endif %}>
  <div class="p-5 mb-4">
    <div class="container py-3">
      <div class="d-flex align-items-center gap-4 flex-wrap">
        {% if productImage %}
        <img src="/images/{{ productImage }}" height="56" class="flex-shrink-0">
        {% endif %}
        <div>
          <h1 class="display-5 fw-bold mb-1">{{ title }}</h1>
          <p class="fs-4 mb-0">{{ description }}</p>
        </div>
      </div>
    </div>
  </div>
</header>
<article>
  {{ content | safe }}
  <section class="py-5 border-top text-center">
    <div class="container">
      {% if productUrl %}
      <a href="{{ productUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-success btn-lg px-5">
        Acessar {{ title }} <i class="bi bi-box-arrow-up-right ms-2"></i>
      </a>
      {% endif %}
      <div class="mt-4">
        <a href="/#products"><i class="bi bi-chevron-left"></i> Voltar para Produtos</a>
      </div>
    </div>
  </section>
</article>
